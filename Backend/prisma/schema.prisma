// =================== Sprint 10 — Tax-on-lines ===================

/// Tax fields are added inline to SalesInvoiceLine / SupplierBillLine / etc.
/// New table tracks the tax-on-document totals for fast roll-ups.
model DocumentTaxSummary {
  id               String   @id @default(cuid())
  companyId        String   @map("company_id")
  /// "SI" / "SC" / "VI" / "VC"
  documentKind     String   @map("document_kind")
  documentId       String   @map("document_id")
  /// "gst" / "adt" / "fed" / "wht"
  taxCode          String   @map("tax_code")
  taxRate          Decimal  @default(0) @db.Decimal(8, 4) @map("tax_rate")
  taxBase          Decimal  @default(0) @db.Decimal(18, 4) @map("tax_base")
  taxAmount        Decimal  @default(0) @db.Decimal(18, 4) @map("tax_amount")
  nominalCode      String?  @map("nominal_code")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([companyId, documentKind, documentId])
  @@index([companyId, taxCode])
  @@map("document_tax_summary")
}
