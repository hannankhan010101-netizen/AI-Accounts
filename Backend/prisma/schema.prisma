// --- Cross-cutting ---

model Attachment {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  fileName   String   @map("file_name")
  storageKey String   @map("storage_key")
  mimeType   String?  @map("mime_type")
  byteSize   Int      @map("byte_size")
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, entityType, entityId])
  @@map("attachments")
}

model DocumentNumberSequence {
  id        String @id @default(cuid())
  companyId String @map("company_id")
  key       String
  nextValue Int    @map("next_value")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@map("document_number_sequences")
}

model ImportJob {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  jobType    String   @map("job_type")
  status     String   @default("pending")
  fileName   String?  @map("file_name")
  /// Inline rows for API-driven imports (CSV parsed client-side or JSON upload).
  payload    Json     @default("{}")
  errorCount Int      @default(0) @map("error_count")
  resultSummary String? @map("result_summary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@map("import_jobs")
}

/// Saved line-grid templates for SI/VI/bank vouchers — FA §3.3.
model TransactionTemplate {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  /// e.g. sales_invoice, supplier_bill, bank_payment
  module    String
  name      String
  payload   Json     @default("{}")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, module])
  @@map("transaction_templates")
}

/// Scheduled recurring documents — FA §3.3.
model RecurringSchedule {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  name        String
  /// sales_invoice, supplier_bill, bank_payment, journal
  module      String
  frequency   String    @default("monthly")
  interval    Int       @default(1)
  nextRunDate DateTime  @map("next_run_date")
  endDate     DateTime? @map("end_date")
  isActive    Boolean   @default(true) @map("is_active")
  payload     Json      @default("{}")
  lastRunAt   DateTime? @map("last_run_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isActive, nextRunDate])
  @@map("recurring_schedules")
}

/// Durable async work queue (imports, report runs).
model OutboxEvent {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  eventType    String    @map("event_type")
  payload      Json      @default("{}")
  status       String    @default("pending")
  attempts     Int       @default(0)
  lastError    String?   @map("last_error")
  lockedAt     DateTime? @map("locked_at")
  nextAttemptAt DateTime? @map("next_attempt_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  processedAt  DateTime? @map("processed_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status, createdAt])
  @@index([createdAt])
  @@map("outbox_events")
}

/// Persisted report execution (replaces in-memory runs).
model ReportRun {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  reportId   String   @map("report_id")
  status     String   @default("pending")
  criteria   Json     @default("{}")
  rowCount   Int      @default(0) @map("row_count")
  rows       Json     @default("[]")
  /// Filesystem or object-store path when row payload is stored externally (Phase 2).
  storageKey String?  @map("storage_key")
  errorMessage String? @map("error_message")
  createdAt  DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, reportId, createdAt])
  @@index([companyId, status, createdAt])
  @@index([companyId, status, completedAt], map: "idx_step2_report_runs_completed")
  @@map("report_runs")
}

/// Bank reconciliation session — catalog §4.5.
