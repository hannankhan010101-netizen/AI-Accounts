  linkedPaymentId String?  @unique @map("linked_payment_id")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, chequeDate])
  @@index([companyId, supplierId, issuedDate], map: "idx_step2_pdc_issued_supplier_date")
  @@map("pdc_issued")
}

