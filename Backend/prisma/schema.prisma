  voucherNumber     String   @map("voucher_number")
  transferDate      DateTime @map("transfer_date")
  fromBankAccountId String   @map("from_bank_account_id")
  toBankAccountId   String   @map("to_bank_account_id")
  totalAmount       Decimal  @map("total_amount") @db.Decimal(18, 4)
  status            String   @default("posted")
  /// GL journal: DR to-bank nominal, CR from-bank nominal.
  journalId         String?  @unique @map("journal_id")
  reconciledAt      DateTime? @map("reconciled_at")
  createdAt         DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, transferDate])
  @@index([companyId, transferDate, id], map: "idx_step2_bank_transfers_keyset")
  @@map("bank_transfers")
