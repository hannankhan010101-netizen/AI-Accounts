// Fast Accounts — phased data model (Phase 1 foundation + Phase 2–4 operational + cross-cutting)
// Run: prisma generate && prisma migrate dev
//
// Step 2 migration-only indexes (partial / GIN — not expressible as @@index):
//   idx_step2_products_active_code, idx_step2_*_draft (6), idx_step2_audit_transaction_type_trgm,
//   idx_step2_users_*_trgm (3), idx_step2_outbox_pending_claim, idx_step2_journal_lines_project
// See: migrations/20260610120000_step2_composite_indexes/migration.sql + sql/index_registry.py

generator client {
  provider                     = "prisma-client-py"
  interface                    = "asyncio"
  recursive_type_depth         = 5
  enable_experimental_decimal  = true
  output                       = "../src/prisma_generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Phase 1: tenancy, identity, RBAC, COA, tax, settings ---

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships       CompanyMembership[]
  roles               Role[]
  businessInformation BusinessInformation?
  smartSettings       SmartSettings?
  lockDateSettings    LockDateSettings?
  taxesYearEnd        TaxesYearEndConfig?
  coaCategories       CoaCategory[]
  bankAccounts        BankAccount[]
  customers           Customer[]
  suppliers           Supplier[]
  products            Product[]
  projects            Project[]
  locations           Location[]
  journals            Journal[]
  attachments         Attachment[]
  importJobs          ImportJob[]
  auditLogEntries     AuditLogEntry[]
  documentSequences   DocumentNumberSequence[]
  approvalPolicies    ApprovalPolicy[]
  salesInvoices       SalesInvoice[]
  supplierBills       SupplierBill[]
  bankPayments        BankPayment[]
  salesReceipts       SalesReceipt[]
  supplierPayments    SupplierPayment[]
  bankReceipts        BankReceipt[]
  bankTransfers       BankTransfer[]
  quotations          Quotation[]
  salesOrders         SalesOrder[]
  purchaseOrders      PurchaseOrder[]
  salesCredits        SalesCredit[]
  supplierCredits     SupplierCredit[]
  stockAdjustments    StockAdjustment[]
  stockTransfers      StockTransfer[]
  productBatches      ProductBatch[]
  deliveryNotes       DeliveryNote[]
  goodsReceiptNotes   GoodsReceiptNote[]
  pdcReceived         PostDatedChequeReceived[]
  pdcIssued           PostDatedChequeIssued[]
  outboxEvents        OutboxEvent[]
  reportRuns          ReportRun[]
  bankReconciliations BankReconciliation[]
  goodsIssues         GoodsIssue[]
  approvalRequests    ApprovalRequest[]
  assemblyTemplates   AssemblyTemplate[]
  assemblyJobs        AssemblyJob[]
  moduleEntitlements  CompanyModuleEntitlement[]
  customFieldDefinitions CustomFieldDefinition[]
  subscriptionRecord  SubscriptionRecord?
  fxRevaluationRuns   FxRevaluationRun[]
  digitalInvoiceSubmissions DigitalInvoiceSubmission[]
  paymentGatewayTransactions PaymentGatewayTransaction[]
  userOnboardingStates       UserOnboardingState[]
  onboardingReleaseItems     OnboardingReleaseItem[]
  assistantThreads           AssistantThread[]
  budgets                    Budget[]
  transactionTemplates       TransactionTemplate[]
  recurringSchedules         RecurringSchedule[]
  customerAdvanceReturns     CustomerAdvanceReturn[]
  supplierAdvanceReturns     SupplierAdvanceReturn[]
  companyModuleConfigs       CompanyModuleConfig[]
  fieldSecurityPolicies      FieldSecurityPolicy[]
  userDataAssignments        UserDataAssignment[]
}

/// AI copilot conversation thread — per user per company.
model AssistantThread {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  userId    String   @map("user_id")
  locale    String   @default("en")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AssistantMessage[]

  @@index([companyId, userId])
  @@map("assistant_threads")
}

model AssistantMessage {
  id          String   @id @default(cuid())
  threadId    String   @map("thread_id")
  role        String
  content     String   @default("")
  toolName    String?  @map("tool_name")
  toolPayload Json?    @map("tool_payload")
  createdAt   DateTime @default(now()) @map("created_at")

  thread AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("assistant_messages")
}

/// Platform-wide What's New (all tenants) — P52.
model PlatformOnboardingRelease {
  id          String   @id @default(cuid())
  releaseKey  String   @unique @map("release_key")
  version     String   @default("1")
  title       String
  summary     String
  publishedAt String   @map("published_at")
  tourId      String?  @map("tour_id")
  href        String?
  permissions Json     @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("platform_onboarding_releases")
}

/// Tenant-managed What's New entries (CMS) — P51. Merged with platform catalog.
model OnboardingReleaseItem {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  releaseKey  String   @map("release_key")
  version     String   @default("1")
  title       String
  summary     String
  publishedAt String   @map("published_at")
  tourId      String?  @map("tour_id")
  href        String?
  permissions Json     @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, releaseKey])
  @@index([companyId, isActive])
  @@map("onboarding_release_items")
}

/// Per-user guided tour progress and analytics buffer — P48.
model UserOnboardingState {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  userId    String   @map("user_id")
  payload   Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@map("user_onboarding_states")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  phone          String?
  isActive       Boolean  @default(true) @map("is_active")
  /// When false, user must complete ``signup`` email OTP before login.
  emailVerified  Boolean  @default(true) @map("email_verified")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  memberships         CompanyMembership[]
  lockDatePerUserRows LockDatePerUser[]
  otpChallenges       AuthOtpChallenge[]
  onboardingStates    UserOnboardingState[]
  assistantThreads    AssistantThread[]
}

/// One-time codes for email verification (signup) and password reset.
model AuthOtpChallenge {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  purpose   String
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("auth_otp_challenges")
}

model CompanyMembership {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  userId      String   @map("user_id")
  roleId      String?  @map("role_id")
  isDefault   Boolean  @default(false) @map("is_default")
  ipAllowlist String?  @map("ip_allowlist")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  membershipRoles MembershipRole[]
  dataAssignments   UserDataAssignment[]

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([companyId, roleId], map: "idx_step2_memberships_company_role")
  @@map("company_memberships")
}

model Role {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  name         String
  code         String?  @map("code")
  description  String?
  parentRoleId String?  @map("parent_role_id")
  isSystem     Boolean  @default(false) @map("is_system")
  isTemplate   Boolean  @default(false) @map("is_template")
  sortOrder    Int      @default(0) @map("sort_order")
  permissions  Json     @default("[]") // legacy JSON; dual-write with role_permissions
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentRole         Role?                @relation("RoleHierarchy", fields: [parentRoleId], references: [id], onDelete: SetNull)
  childRoles         Role[]               @relation("RoleHierarchy")
  memberships        CompanyMembership[]
  membershipRoles    MembershipRole[]
  rolePermissions    RolePermission[]
  fieldSecurityPolicies FieldSecurityPolicy[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, parentRoleId])
  @@map("roles")
}

/// Normalized permission catalog (seeded from permission_registry).
model PermissionDefinition {
  code       String @id
  module     String
  resource   String
  action     String
  label      String
  groupLabel String? @map("group_label")
  sortOrder  Int     @default(0) @map("sort_order")

  rolePermissions RolePermission[]

  @@index([module, resource])
  @@map("permission_definitions")
}

/// Role ↔ permission grants (replaces JSON over time).
model RolePermission {
  roleId         String  @map("role_id")
  permissionCode String  @map("permission_code")
  granted        Boolean @default(true)

  role       Role                 @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission PermissionDefinition @relation(fields: [permissionCode], references: [code], onDelete: Cascade)

  @@id([roleId, permissionCode])
  @@map("role_permissions")
}

/// Multi-role assignment per company membership.
model MembershipRole {
  membershipId String  @map("membership_id")
  roleId       String  @map("role_id")
  isPrimary    Boolean @default(false) @map("is_primary")

  membership CompanyMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       Role              @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([membershipId, roleId])
  @@index([roleId])
  @@map("membership_roles")
}

/// Per-company module kill-switch and visibility (Access Control).
model CompanyModuleConfig {
  companyId       String  @map("company_id")
  moduleCode      String  @map("module_code")
  enabled         Boolean @default(true)
  sidebarVisible  Boolean @default(true) @map("sidebar_visible")
  routesEnabled   Boolean @default(true) @map("routes_enabled")
  apiEnabled      Boolean @default(true) @map("api_enabled")
  reportsEnabled  Boolean @default(true) @map("reports_enabled")
  widgetsEnabled  Boolean @default(true) @map("widgets_enabled")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, moduleCode])
  @@map("company_module_config")
}

/// Field-level security per role.
model FieldSecurityPolicy {
  id          String @id @default(cuid())
  companyId   String @map("company_id")
  roleId      String @map("role_id")
  fieldKey    String @map("field_key")
  accessLevel String @map("access_level") // view | edit | hidden

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([companyId, roleId, fieldKey])
  @@index([roleId])
  @@map("field_security_policies")
}

/// Data scope restrictions per membership.
model UserDataAssignment {
  id           String @id @default(cuid())
  companyId    String @map("company_id")
  membershipId String @map("membership_id")
  scopeType    String @map("scope_type") // customer | supplier | location | warehouse | project | company
  scopeId      String @map("scope_id")

  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  membership CompanyMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, scopeType, scopeId])
  @@index([membershipId])
  @@map("user_data_assignments")
}

model BusinessInformation {
  id               String  @id @default(cuid())
  companyId        String  @unique @map("company_id")
  businessName     String? @map("business_name")
  addressLine1     String? @map("address_line_1")
  addressLine2     String? @map("address_line_2")
  addressLine3     String? @map("address_line_3")
  addressLine4     String? @map("address_line_4")
  addressLine5     String? @map("address_line_5")
  branchName       String? @map("branch_name")
  phoneNumber      String? @map("phone_number")
  mobileNumber     String? @map("mobile_number")
  emailAddress     String? @map("email_address")
  websiteAddress   String? @map("website_address")
  logoUrl          String? @map("logo_url")
  cnic             String?
  stn              String?
  ntn              String?
  applyOnAllPrints Boolean @default(false) @map("apply_on_all_prints")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("business_information")
}

model SmartSettings {
  id        String   @id @default(cuid())
  companyId String   @unique @map("company_id")
  payload   Json     @default("{}") // accordion blocks: others, sales, purchases, bank, FA, auto-codes, etc.
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("smart_settings")
}

model LockDateSettings {
  id              String    @id @default(cuid())
  companyId       String    @unique @map("company_id")
  globalLockDate  DateTime? @map("global_lock_date")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  perUserExtensions LockDatePerUser[]

  @@map("lock_date_settings")
}

model LockDatePerUser {
  id                 String   @id @default(cuid())
  lockDateSettingsId String   @map("lock_date_settings_id")
  userId             String   @map("user_id")
  extendedLockDate   DateTime @map("extended_lock_date")

  lockDateSettings LockDateSettings @relation(fields: [lockDateSettingsId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lockDateSettingsId, userId])
  @@map("lock_date_per_user")
}

model TaxesYearEndConfig {
  id           String   @id @default(cuid())
  companyId    String   @unique @map("company_id")
  yearEndDate  DateTime? @map("year_end_date")
  taxDisplay   Json     @default("{}") @map("tax_display")
  gstRates     Json     @default("[]") @map("gst_rates")
  fedRates     Json     @default("[]") @map("fed_rates")
  adtRates     Json     @default("[]") @map("adt_rates")
  whtRates     Json     @default("[]") @map("wht_rates")
  taxRegions   Json     @default("[]") @map("tax_regions")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("taxes_year_end_config")
}

model CoaCategory {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  code         String
  name         String
  sortOrder    Int      @default(0) @map("sort_order")
  /// Income / Expense / Asset / Liability / Equity / Other — drives P&L vs Balance Sheet classification.
  categoryType String   @default("Other") @map("category_type")

  company  Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sections CoaSection[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("coa_categories")
}

model CoaSection {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  code       String
  name       String
  sortOrder  Int      @default(0) @map("sort_order")

  category CoaCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nominals NominalAccount[]

  @@unique([categoryId, code])
  @@index([categoryId])
  @@map("coa_sections")
}

model NominalAccount {
  id          String  @id @default(cuid())
  sectionId   String  @map("section_id")
  code        String
  name        String
  description String?
  isChargeDeduction Boolean @default(false) @map("is_charge_deduction")

  section CoaSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]

  @@unique([sectionId, code])
  @@index([sectionId])
  @@map("nominal_accounts")
}

// --- Phase 2: masters ---

model BankAccount {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String
  nominalCode String?  @map("nominal_code")
  currency    String   @default("PKR")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("bank_accounts")
}

model Customer {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  code         String
  name         String
  email        String?
  phone        String?
  customFields Json     @default("{}") @map("custom_fields")
  createdAt    DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, code, id], map: "idx_step2_customers_code")
  @@map("customers")
}

model Supplier {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  code      String
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, code, id], map: "idx_step2_suppliers_code")
  @@map("suppliers")
}

model Product {
  id                       String   @id @default(cuid())
  companyId                String   @map("company_id")
  code                     String
  name                     String
  category                 String?
  unit                     String   @default("EA")
  cost                     Decimal  @default(0) @db.Decimal(18, 4)
  salePrice                Decimal  @default(0) @map("sale_price") @db.Decimal(18, 4)
  isStock                  Boolean  @default(true) @map("is_stock")
  isArchived               Boolean  @default(false) @map("is_archived")
  customFields             Json     @default("{}") @map("custom_fields")
  primaryImageAttachmentId String?  @map("primary_image_attachment_id")
  lowStockLevel            Decimal? @map("low_stock_level") @db.Decimal(18, 4)
  binLocation              String?  @map("bin_location")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uoms      ProductUom[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isArchived])
  @@index([companyId, name])
  @@index([companyId, category])
  @@map("products")
}

/// Subscription / license gate per module — P11.
model CompanyModuleEntitlement {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  moduleCode String   @map("module_code")
  enabled    Boolean  @default(true)
  updatedAt  DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, moduleCode])
  @@index([companyId])
  @@map("company_module_entitlements")
}

/// Configurable custom fields for customers and products — P11.
model CustomFieldDefinition {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  entityType      String   @map("entity_type")
  fieldKey        String   @map("field_key")
  label           String
  fieldType       String   @default("text") @map("field_type")
  isRequired      Boolean  @default(false) @map("is_required")
  picklistOptions Json?    @map("picklist_options")
  createdAt       DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, entityType, fieldKey])
  @@index([companyId, entityType])
  @@map("custom_field_definitions")
}

/// External billing provider mirror (Stripe/etc.) — P12 stub.
model SubscriptionRecord {
  id                 String    @id @default(cuid())
  companyId          String    @unique @map("company_id")
  planCode           String    @default("standard") @map("plan_code")
  externalCustomerId String?   @map("external_customer_id")
  status             String    @default("active")
  currentPeriodEnd   DateTime? @map("current_period_end")
  metadata           Json      @default("{}")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("subscription_records")
}

/// Multi-UOM price tiers per product — P11.
model ProductUom {
  id               String  @id @default(cuid())
  companyId        String  @map("company_id")
  productId        String  @map("product_id")
  unitCode         String  @map("unit_code")
  conversionFactor Decimal @default(1) @map("conversion_factor") @db.Decimal(18, 6)
  salePrice        Decimal @default(0) @map("sale_price") @db.Decimal(18, 4)
  isDefault        Boolean @default(false) @map("is_default")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, productId, unitCode])
  @@index([productId])
  @@map("product_uoms")
}

model Project {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  code      String
  name      String
  isActive  Boolean  @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@index([companyId])
  @@map("projects")
}

model Location {
  id          String  @id @default(cuid())
  companyId   String  @map("company_id")
  code        String
  name        String
  isMain      Boolean @default(false) @map("is_main")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@index([companyId])
  @@map("locations")
}

// --- Phase 3–4: journals + commercial documents (simplified voucher shells for posting hooks) ---

model Journal {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  journalNumber String @map("journal_number")
  journalDate DateTime @map("journal_date")
  refNo       String?  @map("ref_no")
  totalAmount Decimal  @map("total_amount") @db.Decimal(18, 4)
  status      String   @default("posted")
  /// e.g. SALES_INVOICE, STOCK_ADJUSTMENT — P0 traceability
  sourceType  String?  @map("source_type")
  sourceId    String?  @map("source_id")
  correlationId String? @map("correlation_id")
  reversesJournalId String? @map("reverses_journal_id")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalLine[]

  @@index([companyId, journalDate])
  @@index([companyId, status, journalDate])
  @@index([companyId, sourceType, sourceId])
  @@map("journals")
}

model JournalLine {
  id         String  @id @default(cuid())
  journalId  String  @map("journal_id")
  nominalCode String @map("nominal_code")
  /// Optional FK to chart nominal (P3); ``nominalCode`` remains for legacy queries.
  nominalAccountId String? @map("nominal_account_id")
  debit      Decimal @default(0) @db.Decimal(18, 4)
  credit     Decimal @default(0) @db.Decimal(18, 4)
  projectCode String? @map("project_code")

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  nominalAccount NominalAccount? @relation(fields: [nominalAccountId], references: [id], onDelete: SetNull)

  @@index([journalId])
  @@index([nominalCode, journalId])
  @@index([nominalAccountId])
  @@map("journal_lines")
}

model SalesInvoice {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  invoiceNumber String   @map("invoice_number")
  invoiceDate   DateTime @map("invoice_date")
  customerId    String   @map("customer_id")
  /// Write-time snapshot (Step 3) — avoids JOIN to customers on reads.
  customerCode  String?  @map("customer_code")
  customerName  String?  @map("customer_name")
  status        String   @default("draft")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(18, 4)
  /// Open balance after receipt allocations (Phase 3 denorm).
  remainingAmount Decimal @default(0) @map("remaining_amount") @db.Decimal(18, 4)
  /// GL journal that posted this invoice (DR AR / CR Sales). Null when defaults missing at create time.
  journalId     String?  @unique @map("journal_id")
  customFields  Json     @default("{}") @map("custom_fields")
  createdAt     DateTime @default(now()) @map("created_at")

  company     Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines       SalesInvoiceLine[]
  allocations SalesReceiptAllocation[]

  @@index([companyId, invoiceDate])
  @@index([companyId, customerId, invoiceDate])
  @@index([companyId, status])
  @@index([companyId, status, invoiceDate, id], map: "idx_step2_si_keyset")
  @@index([companyId, customerId, status, invoiceDate], map: "idx_step2_si_customer_status_date")
  @@map("sales_invoices")
}

model SalesInvoiceLine {
  id             String  @id @default(cuid())
  salesInvoiceId String  @map("sales_invoice_id")
  productCode    String? @map("product_code")
  quantity       Decimal @db.Decimal(18, 4)
  rate           Decimal @db.Decimal(18, 4)
  /// Net before tax (qty × rate).
  lineSubtotal   Decimal @default(0) @map("line_subtotal") @db.Decimal(18, 4)
  gstCode        String? @map("gst_code")
  gstRate        Decimal @default(0) @map("gst_rate") @db.Decimal(8, 4)
  taxAmount      Decimal @default(0) @map("tax_amount") @db.Decimal(18, 4)
  lineTotal      Decimal @map("line_total") @db.Decimal(18, 4)
  projectCode    String? @map("project_code")
  description    String?
  descriptionFields Json   @default("{}") @map("description_fields")
  batchNumber    String? @map("batch_number")
  expiryDate     DateTime? @map("expiry_date")

  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)

  @@index([salesInvoiceId])
  @@map("sales_invoice_lines")
}

model SupplierBill {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  billNumber  String   @map("bill_number")
  billDate    DateTime @map("bill_date")
  supplierId  String   @map("supplier_id")
  /// Write-time snapshot (Step 3) — avoids JOIN to suppliers on reads.
  supplierCode String? @map("supplier_code")
  supplierName String? @map("supplier_name")
  status      String   @default("draft")
  totalAmount Decimal  @map("total_amount") @db.Decimal(18, 4)
  remainingAmount Decimal @default(0) @map("remaining_amount") @db.Decimal(18, 4)
  /// GL journal that posted this bill (DR Expense / CR AP). Null when defaults missing at create time.
  journalId   String?  @unique @map("journal_id")
  customFields Json    @default("{}") @map("custom_fields")
  createdAt   DateTime @default(now()) @map("created_at")

  company     Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines       SupplierBillLine[]
  allocations SupplierPaymentAllocation[]

  @@index([companyId, billDate])
  @@index([companyId, supplierId, billDate])
  @@index([companyId, status])
  @@index([companyId, status, billDate, id], map: "idx_step2_sb_keyset")
  @@index([companyId, supplierId, status, billDate], map: "idx_step2_sb_supplier_status_date")
  @@map("supplier_bills")
}

model SupplierBillLine {
  id             String  @id @default(cuid())
  supplierBillId String  @map("supplier_bill_id")
  productCode    String? @map("product_code")
  quantity       Decimal @db.Decimal(18, 4)
  rate           Decimal @db.Decimal(18, 4)
  lineSubtotal   Decimal @default(0) @map("line_subtotal") @db.Decimal(18, 4)
  gstCode        String? @map("gst_code")
  gstRate        Decimal @default(0) @map("gst_rate") @db.Decimal(8, 4)
  taxAmount      Decimal @default(0) @map("tax_amount") @db.Decimal(18, 4)
  lineTotal      Decimal @map("line_total") @db.Decimal(18, 4)
  description    String?
  descriptionFields Json   @default("{}") @map("description_fields")
  batchNumber    String? @map("batch_number")
  expiryDate     DateTime? @map("expiry_date")

  supplierBill SupplierBill @relation(fields: [supplierBillId], references: [id], onDelete: Cascade)

  @@index([supplierBillId])
  @@map("supplier_bill_lines")
}

model BankPayment {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  voucherNumber  String   @map("voucher_number")
  paymentDate    DateTime @map("payment_date")
  bankAccountId  String   @map("bank_account_id")
  /// Counterpart nominal for the single-line journal (DR this code, CR bank account's nominal).
  /// When null, the payment is recorded but no journal posts.
  nominalCode    String?  @map("nominal_code")
  totalAmount    Decimal  @map("total_amount") @db.Decimal(18, 4)
  status         String   @default("posted")
  /// GL journal that posted this payment.
  journalId      String?  @unique @map("journal_id")
  reconciledAt   DateTime? @map("reconciled_at")
  customFields   Json     @default("{}") @map("custom_fields")
  createdAt      DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerAdvanceReturn CustomerAdvanceReturn?

  @@index([companyId, paymentDate])
  @@index([companyId, paymentDate, id], map: "idx_step2_bank_payments_keyset")
  @@map("bank_payments")
}

/// Customer receipt (SR). Money in, cleared against AR via allocations.
model SalesReceipt {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  receiptNumber String   @map("receipt_number")
  receiptDate   DateTime @map("receipt_date")
  customerId    String   @map("customer_id")
  customerCode  String?  @map("customer_code")
  customerName  String?  @map("customer_name")
  bankAccountId String   @map("bank_account_id")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(18, 4)
  status        String   @default("posted")
  /// GL journal: DR bank's nominal, CR receivables nominal.
  journalId     String?  @unique @map("journal_id")
  reconciledAt  DateTime? @map("reconciled_at")
  customFields  Json     @default("{}") @map("custom_fields")
  createdAt     DateTime @default(now()) @map("created_at")

  company     Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  allocations SalesReceiptAllocation[]
  advanceReturns CustomerAdvanceReturn[]

  @@index([companyId, receiptDate])
  @@index([companyId, customerId, receiptDate], map: "idx_step2_sr_customer_date")
  @@map("sales_receipts")
}

/// Supplier payment (VP). Money out, cleared against AP via allocations.
model SupplierPayment {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  voucherNumber String   @map("voucher_number")
  paymentDate   DateTime @map("payment_date")
  supplierId    String   @map("supplier_id")
  supplierCode  String?  @map("supplier_code")
  supplierName  String?  @map("supplier_name")
  bankAccountId String   @map("bank_account_id")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(18, 4)
  status        String   @default("posted")
  /// GL journal: DR payables nominal, CR bank's nominal.
  journalId     String?  @unique @map("journal_id")
  reconciledAt  DateTime? @map("reconciled_at")
  customFields  Json     @default("{}") @map("custom_fields")
  createdAt     DateTime @default(now()) @map("created_at")

  company     Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  allocations SupplierPaymentAllocation[]
  advanceReturns SupplierAdvanceReturn[]

  @@index([companyId, paymentDate])
  @@index([companyId, supplierId, paymentDate], map: "idx_step2_sp_supplier_date")
  @@map("supplier_payments")
}

/// Allocation of a customer receipt against a specific sales invoice (FIFO or explicit).
model SalesReceiptAllocation {
  id             String  @id @default(cuid())
  salesReceiptId String  @map("sales_receipt_id")
  salesInvoiceId String  @map("sales_invoice_id")
  amount         Decimal @db.Decimal(18, 4)

  salesReceipt SalesReceipt @relation(fields: [salesReceiptId], references: [id], onDelete: Cascade)
  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id])

  @@index([salesReceiptId])
  @@index([salesInvoiceId])
  @@map("sales_receipt_allocations")
}

/// Allocation of a supplier payment against a specific supplier bill.
model SupplierPaymentAllocation {
  id                String  @id @default(cuid())
  supplierPaymentId String  @map("supplier_payment_id")
  supplierBillId    String  @map("supplier_bill_id")
  amount            Decimal @db.Decimal(18, 4)

  supplierPayment SupplierPayment @relation(fields: [supplierPaymentId], references: [id], onDelete: Cascade)
  supplierBill    SupplierBill    @relation(fields: [supplierBillId], references: [id])

  @@index([supplierPaymentId])
  @@index([supplierBillId])
  @@map("supplier_payment_allocations")
}

/// Customer advance returned to payer — FA §5.8 (bank payment out, DR AR / CR bank).
model CustomerAdvanceReturn {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  salesReceiptId String   @map("sales_receipt_id")
  bankPaymentId  String   @unique @map("bank_payment_id")
  amount         Decimal  @db.Decimal(18, 4)
  returnDate     DateTime @map("return_date")
  createdAt      DateTime @default(now()) @map("created_at")

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesReceipt SalesReceipt @relation(fields: [salesReceiptId], references: [id], onDelete: Cascade)
  bankPayment  BankPayment  @relation(fields: [bankPaymentId], references: [id], onDelete: Restrict)

  @@index([salesReceiptId])
  @@map("customer_advance_returns")
}

/// Supplier advance returned to company — FA §6.4 (bank receipt in, DR bank / CR AP).
model SupplierAdvanceReturn {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  supplierPaymentId String   @map("supplier_payment_id")
  bankReceiptId     String   @unique @map("bank_receipt_id")
  amount            Decimal  @db.Decimal(18, 4)
  returnDate        DateTime @map("return_date")
  createdAt         DateTime @default(now()) @map("created_at")

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierPayment SupplierPayment @relation(fields: [supplierPaymentId], references: [id], onDelete: Cascade)
  bankReceipt     BankReceipt     @relation(fields: [bankReceiptId], references: [id], onDelete: Restrict)

  @@index([supplierPaymentId])
  @@map("supplier_advance_returns")
}

/// Bank receipt (IR). Money in from non-AR sources (refunds, capital, etc.).
model BankReceipt {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  voucherNumber String   @map("voucher_number")
  receiptDate   DateTime @map("receipt_date")
  bankAccountId String   @map("bank_account_id")
  /// Counterpart nominal (CR side) — typically an income or refund-control code.
  nominalCode   String?  @map("nominal_code")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(18, 4)
  status        String   @default("posted")
  /// GL journal: DR bank's nominal, CR counterpart.
  journalId     String?  @unique @map("journal_id")
  reconciledAt  DateTime? @map("reconciled_at")
  customFields  Json     @default("{}") @map("custom_fields")
  createdAt     DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierAdvanceReturn SupplierAdvanceReturn?

  @@index([companyId, receiptDate])
  @@index([companyId, receiptDate, id], map: "idx_step2_bank_receipts_keyset")
  @@map("bank_receipts")
}

/// Quotation (SQ) — pre-sale offer. No GL impact.
model Quotation {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  quotationNumber String   @map("quotation_number")
  quotationDate   DateTime @map("quotation_date")
  customerId      String   @map("customer_id")
  customerCode    String?  @map("customer_code")
  customerName    String?  @map("customer_name")
  /// draft | approved | rejected | accepted | converted
  status          String   @default("draft")
  totalAmount     Decimal  @map("total_amount") @db.Decimal(18, 4)
  createdAt       DateTime @default(now()) @map("created_at")

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   QuotationLine[]

  @@index([companyId, quotationDate])
  @@index([companyId, customerId, quotationDate], map: "idx_step2_quotations_customer_date")
  @@map("quotations")
}

model QuotationLine {
