/// Stock adjustment voucher — catalog §7.3.
model StockAdjustment {
  id             String                @id @default(cuid())
  companyId      String                @map("company_id")
  voucherNumber  String                @map("voucher_number")
  adjustmentDate DateTime              @map("adjustment_date")
  /// "increase" | "decrease" | "writeoff"
  reason         String                @default("adjustment")
  notes          String?
  status         String                @default("draft")
  journalId      String?               @unique @map("journal_id")
  createdAt      DateTime              @default(now()) @map("created_at")

  company Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   StockAdjustmentLine[]

  @@index([companyId, adjustmentDate])
  @@index([companyId, adjustmentDate, id], map: "idx_step2_stock_adjustments_keyset")
  @@map("stock_adjustments")
}

model StockAdjustmentLine {
  id                String  @id @default(cuid())
  stockAdjustmentId String  @map("stock_adjustment_id")
  productCode       String  @map("product_code")
