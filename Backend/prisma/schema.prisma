/// Post-Dated Cheque Received (PDCR) — catalog §5.7.
model PostDatedChequeReceived {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  voucherNumber   String   @map("voucher_number")
  chequeNumber    String   @map("cheque_number")
  bankName        String   @map("bank_name")
  customerId      String   @map("customer_id")
  customerCode    String?  @map("customer_code")
  customerName    String?  @map("customer_name")
  receivedDate    DateTime @map("received_date")
  chequeDate      DateTime @map("cheque_date")
  amount          Decimal  @db.Decimal(18, 4)
  /// "pending" | "presented" | "cleared" | "bounced" | "cancelled"
  status          String   @default("pending")
  /// SalesReceipt id created on clearing (null until cleared).
  linkedReceiptId String?  @unique @map("linked_receipt_id")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, chequeDate])
  @@index([companyId, customerId, receivedDate], map: "idx_step2_pdc_received_customer_date")
  @@map("pdc_received")
}

