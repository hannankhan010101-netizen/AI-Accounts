# Production API environment (Railway / Docker / similar)
# Copy to Backend/.env.production.local, fill values, then:
#   python scripts/_prod_env_check.py --strict --env-file Backend/.env.production.local
# Do not commit real values — .env.production.local is gitignored.

# Runtime — Supabase transaction pooler :6543
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Migrations / release command — session pooler :5432
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?schema=public&sslmode=require"

JWT_SECRET_KEY="<random-64-chars-minimum-32>"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="30"
REFRESH_TOKEN_EXPIRE_DAYS="7"

APP_PUBLIC_URL="https://app.yourdomain.com"
CORS_ORIGINS="https://app.yourdomain.com"
OUTBOX_POLL_ENABLED="1"
AUTH_EXPOSE_OTP_IN_RESPONSE="false"

BREVO_API_KEY="xkeysib-..."
BREVO_SENDER_EMAIL="noreply@your-verified-domain.com"
BREVO_SENDER_NAME="AI-Accounts"
OTP_TTL_MINUTES="15"

# FBR — leave disabled until PRAL credentials; stub mode works for UAT
FBR_PRAL_ENABLED="false"
FBR_PRAL_API_URL=""
FBR_PRAL_API_KEY=""
FBR_RETRY_ENABLED="true"

# PayPro — enable when merchant credentials and webhook URL are ready
PAYPRO_ENABLED="false"
PAYPRO_MERCHANT_ID=""
PAYPRO_API_URL=""
PAYPRO_API_KEY=""
PAYPRO_WEBHOOK_SECRET=""

# Optional
GROQ_ENABLED="false"
GROQ_API_KEY=""
