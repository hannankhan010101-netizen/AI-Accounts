# PostgreSQL — local example
# DATABASE_URL="postgresql://user:password@localhost:5432/fast_accounts?schema=public"
# Supabase session pooler (IPv4) — replace project ref, region, and URL-encoded password
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?schema=public&sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/fast_accounts?schema=public"
# Migrations only (session pooler :5432) — python scripts/migrate_deploy.py
# DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?schema=public&sslmode=require"
# Public frontend URL (password reset, invites)
APP_PUBLIC_URL="http://localhost:3000"
# Background import/report outbox (set 0 only for local dev if needed)
OUTBOX_POLL_ENABLED="1"
JWT_SECRET_KEY="change-me-in-production-min-32-chars-long"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="30"
REFRESH_TOKEN_EXPIRE_DAYS="7"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001"
# Email OTP / password-reset code lifetime (minutes)
OTP_TTL_MINUTES="15"
# Local dev only: include plaintext devOtp on sign-up / resend / forgot flows (never enable in prod)
AUTH_EXPOSE_OTP_IN_RESPONSE="false"
# Brevo transactional email — https://app.brevo.com (API key + verified sender required)
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="noreply@your-verified-domain.com"
BREVO_SENDER_NAME="AI-Accounts"
# Optional: Brevo SMTP relay (smtp-relay.brevo.com) instead of REST API
# SMTP_HOST="smtp-relay.brevo.com"
# SMTP_PORT="587"
# SMTP_USER="your-brevo-login@email.com"
# SMTP_PASSWORD="your-brevo-smtp-key"
# SMTP_FROM_EMAIL="noreply@your-verified-domain.com"
# SMTP_USE_TLS="true"

# Supabase project (only needed when using Supabase-hosted Postgres/storage)
# SUPABASE_PROJECT_URL=""
# SUPABASE_PUBLISHABLE_KEY=""
# Attachment storage — local disk by default; set the bucket to switch to S3-compatible storage
# ATTACHMENT_UPLOAD_DIR="uploads"
# ATTACHMENT_S3_BUCKET=""
# ATTACHMENT_S3_ENDPOINT=""
# ATTACHMENT_S3_ACCESS_KEY=""
# ATTACHMENT_S3_SECRET_KEY=""
# ATTACHMENT_S3_REGION="us-east-1"

# FBR / PRAL digital invoicing (production)
FBR_PRAL_ENABLED="false"
FBR_PRAL_API_URL=""
FBR_PRAL_API_KEY=""
FBR_RETRY_ENABLED="true"
FBR_MAX_RETRY_COUNT="5"
FBR_RETRY_BASE_MINUTES="15"
# PayPro online payments
PAYPRO_ENABLED="false"
PAYPRO_MERCHANT_ID=""
PAYPRO_API_URL=""
PAYPRO_API_KEY=""
PAYPRO_WEBHOOK_SECRET=""
PAYPRO_WEBHOOK_ALLOWED_IPS=""
# Kuickpay (optional second provider)
KUICKPAY_ENABLED="false"
KUICKPAY_MERCHANT_ID=""
KUICKPAY_API_URL=""
KUICKPAY_API_KEY=""
KUICKPAY_WEBHOOK_SECRET=""
KUICKPAY_WEBHOOK_ALLOWED_IPS=""

# Enterprise AI assistant (Groq) — server-side only; never expose to the browser
GROQ_API_KEY=""
GROQ_ENABLED="true"
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_MAX_TOKENS="2048"
ASSISTANT_RATE_LIMIT_PER_MINUTE="30"
ASSISTANT_MAX_MESSAGE_CHARS="4000"
ASSISTANT_MEMORY_TURNS="20"
# Legacy onboarding LLM (optional; Groq used when GROQ_API_KEY is set)
ONBOARDING_LLM_ENABLED="false"
ONBOARDING_LLM_API_KEY=""
ONBOARDING_LLM_BASE_URL="https://api.groq.com/openai/v1"
ONBOARDING_LLM_MODEL="llama-3.3-70b-versatile"
