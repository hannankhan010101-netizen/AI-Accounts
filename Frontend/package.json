{
  "name": "fast-accounts-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --disable-warning=DEP0060 ./node_modules/next/dist/bin/next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next/cache',{recursive:true,force:true})\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:design": "node scripts/check-design.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:responsive": "playwright test e2e/responsive-shell.spec.ts",
    "test:e2e:parity": "playwright test e2e/parity/smoke.spec.ts"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@tanstack/query-sync-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.25",
    "@types/react-grid-layout": "^1.3.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "decimal.js": "^10.4.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.452.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.3",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8"
  }
}
