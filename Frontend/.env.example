# Local dev: leave unset — Next.js rewrites proxy /api/v1/* to http://127.0.0.1:8000
# NEXT_PUBLIC_API_BASE_URL=

# Production (split API + app hostnames): required — no trailing slash
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# Dev only: override backend proxy target (see next.config.mjs)
# API_PROXY_TARGET=http://127.0.0.1:8000

# Data-ingestion service (Settings → Migrations). Run services/data-ingestion on port 4100.
# Dev only: override ingestion proxy target (see next.config.mjs)
# INGESTION_PROXY_TARGET=http://127.0.0.1:4100
# Production: absolute URL of the ingestion API
# INGESTION_API_URL=http://127.0.0.1:4100/api/v1

# Playwright e2e (npm run test:e2e)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_AUTH_READY=1
# PLAYWRIGHT_SMOKE_ONLY=1
