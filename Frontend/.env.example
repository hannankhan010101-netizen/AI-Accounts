# Local dev: leave unset — Next.js rewrites proxy /api/v1/* to http://127.0.0.1:8000
# NEXT_PUBLIC_API_BASE_URL=

# Production (split API + app hostnames): required — no trailing slash
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# Dev only: override backend proxy target (see next.config.mjs)
# API_PROXY_TARGET=http://127.0.0.1:8000
