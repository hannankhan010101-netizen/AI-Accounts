# Ingestion service database (pipeline metadata — can share PG with Backend)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_accounts?schema=public

# Redis for BullMQ
REDIS_URL=redis://localhost:6379

# AI-Accounts Backend API (target writes)
BACKEND_API_URL=http://127.0.0.1:8000
BACKEND_SERVICE_TOKEN=

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=ai-accounts-imports
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Service
PORT=4100
NODE_ENV=development
CHUNK_SIZE=500
MAX_PREVIEW_ROWS=100
FILE_ENCRYPTION_KEY=change-me-32-byte-base64-key-here==

# Optional: AI mapping suggestions (OpenAI-compatible)
AI_MAPPING_URL=
AI_MAPPING_API_KEY=
