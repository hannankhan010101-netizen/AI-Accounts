# Monorepo — keep secrets and build artifacts out of git

# Env / secrets
.env
.env.*
!.env.example
!.env.production.example
Backend/.env.production.local

# Python
**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.mypy_cache/

# Node
**/node_modules/
**/.next/
**/out/
**/dist/

# Playwright auth state
Frontend/e2e/.auth/

# Uploads / local data
Backend/uploads/*
!Backend/uploads/.gitkeep

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Prisma (keep migrations; ignore local lock noise if regenerated)
# Backend/prisma/migrations/**/migration_lock.toml
